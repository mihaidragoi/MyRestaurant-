<Window x:Class="RestaurantIncercareaDoua.View.RestaurantMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestaurantIncercareaDoua.View"
        mc:Ignorable="d"
        Title="RestaurantMenu" Height="520" Width="870" WindowStartupLocation="CenterScreen">

    <Grid Background="LightSalmon">
        <TabControl Background="AliceBlue" BorderThickness="5" Margin="5">

            <TabItem Header="Menu Restaurant">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Menu Grid.Row="0" Background="Transparent" BorderThickness="0">
                        <MenuItem Header="🛒 Your cart" Command="{Binding ViewCartCommand}" FontWeight="Bold"/>
                    </Menu>

                    <Border Grid.Row="1" Background="WhiteSmoke" CornerRadius="5" Margin="10,5" Padding="10" BorderBrush="LightGray" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Cuvânt cheie: " VerticalAlignment="Center" FontWeight="Bold" Foreground="DarkSlateGray"/>
                            <TextBox Text="{Binding TextCautare, UpdateSourceTrigger=PropertyChanged}" Width="150" Height="24" VerticalContentAlignment="Center"/>

                            <RadioButton x:Name="RbDenumire" Content="După Denumire" IsChecked="True" Margin="15,0,5,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <RadioButton x:Name="RbAlergen" Content="După Alergen" IsChecked="{Binding CautaDupaAlergen}" Margin="5,0,15,0" VerticalAlignment="Center" FontWeight="SemiBold"/>

                            <TextBlock Text="Regulă Alergen: " VerticalAlignment="Center" FontWeight="Bold" Margin="10,0,5,0" Foreground="DarkSlateGray" IsEnabled="{Binding ElementName=RbAlergen, Path=IsChecked}"/>
                            <ComboBox ItemsSource="{Binding OptiuniRegula}" SelectedItem="{Binding RegulaCautare}" Width="110" Height="24" VerticalContentAlignment="Center" IsEnabled="{Binding ElementName=RbAlergen, Path=IsChecked}"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox ItemsSource="{Binding ViewMeniu}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Background="LightSteelBlue" CornerRadius="5" Padding="10,5" Margin="5,15,5,5" Width="800" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Name, StringFormat='📂 {0}'}" FontSize="16" FontWeight="Bold" Foreground="DarkBlue"/>
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListBox.GroupStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="15" Padding="10" Margin="12" Width="220" Height="280">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <Image Source="{Binding ImaginePath}" Height="100" Width="200" Stretch="UniformToFill" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding Denumire}" FontWeight="Bold" FontSize="15" Foreground="DarkRed" TextWrapping="Wrap" Height="40"/>

                                                <TextBlock FontSize="12" Foreground="Gray" Margin="0,2">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding CantitatePortie, StringFormat='Gramaj: {0}g'}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMeniu}" Value="True">
                                                                    <Setter Property="Text" Value="{Binding CantitatiDetaliateMeniu, StringFormat='Componente: {0}'}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBlock Text="{Binding Pret, StringFormat='Preț: {0} RON'}" FontWeight="SemiBold" Foreground="Green" FontSize="14" Margin="0,2"/>
                                                <TextBlock Text="{Binding ListaAlergeniText, StringFormat='⚠️ Alergeni: {0}'}" FontSize="11" Foreground="DimGray" TextWrapping="Wrap" Height="32" FontStyle="Italic" Margin="0,2,0,0"/>

                                                <Button Content="Adaugă în coș" Margin="0,8,0,0" Background="BurlyWood" Cursor="Hand" Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" IsEnabled="{Binding IsDisponibil}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="My Account" IsEnabled="{Binding CanSeeProfile}">
                <StackPanel Margin="50,20" MaxWidth="400" HorizontalAlignment="Left" Background="PeachPuff">
                    <TextBlock Text="Profile Information" FontSize="22" Margin="0,0,0,20"/>
                    <Label Content="Email (cannot be modified)"/>
                    <TextBox Text="{Binding UserEmail}" IsReadOnly="True" Opacity="0.7"/>
                    <Label Content="Address" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding UserAddress}"/>
                    <Label Content="Phone number" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding UserPhone}"/>
                    <Label Content="Password" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding UserPassword}"/>
                    <Button Content="Update Data" Margin="0,30,0,0" Height="35" Background="BurlyWood" Command="{Binding UpdateDataCommand}"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Orders" IsEnabled="{Binding CanOrder}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0" Content="Afișează doar comenzile active" IsChecked="{Binding OnlyActiveOrders}" IsEnabled="{Binding DataContext.IsAngajat, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,0,10" FontWeight="Bold"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding IstoricComenzi}" AutoGenerateColumns="False" CanUserAddRows="False" Background="Bisque">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID Comandă" Binding="{Binding IdComanda}" Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Data" Binding="{Binding DataComanda, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="130" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding SumaTotala, StringFormat='{}{0} RON'}" Width="90" IsReadOnly="True"/>

                            <DataGridTextColumn Header="Livrare Estimată" Binding="{Binding OraEstimativa, StringFormat='{}{0:HH:mm}', TargetNullValue='Necalculat'}" Width="110" IsReadOnly="True"/>

                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140" IsReadOnly="True"/>

                            <DataGridTemplateColumn Header="Acțiuni Disponibile" Width="155">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Vertical">
                                            <Button Content="Avansează Status" Background="LightGreen" Margin="2" Command="{Binding DataContext.ChangeStatusCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" IsEnabled="{Binding DataContext.IsAngajat, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Button Content="Vezi Detalii Complete" Background="LightBlue" Margin="2" Command="{Binding DataContext.SeeDetailsOrderCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            <Button Content="Anulează Comandă" Background="MistyRose" Foreground="Red" FontWeight="Bold" Margin="2" Command="{Binding DataContext.AnuleazaComandaCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" IsEnabled="{Binding DataContext.IsClient, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,15,0,0" IsEnabled="{Binding IsAngajat}">
                        <TextBlock Text="⚠️ Alerte Stoc (Produse pe cale de epuizare):" FontWeight="Bold" Foreground="Red" Margin="0,0,0,5"/>
                        <ListBox ItemsSource="{Binding PreparateEpuizate}" Background="MistyRose" Height="100"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Admin Panel" IsEnabled="{Binding IsAngajat}">
                <Grid Background="GhostWhite" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="10">
                        <TextBlock Text="ADĂUGARE PREPARAT NOU" FontSize="16" FontWeight="Bold" Foreground="DarkSlateGray" Margin="0,0,0,15"/>

                        <Label Content="Categorie Preparat:"/>
                        <ComboBox ItemsSource="{Binding CategoriiDisponibile}" SelectedValue="{Binding NewIdCategorie}" SelectedValuePath="Key" DisplayMemberPath="Value" Margin="0,0,0,10" Height="25" VerticalContentAlignment="Center"/>

                        <Label Content="Denumire Preparat:"/>
                        <TextBox Text="{Binding NewDenumire}" Margin="0,0,0,10"/>
                        <Label Content="Preț (RON):"/>
                        <TextBox Text="{Binding NewPret}" Margin="0,0,0,10"/>
                        <Label Content="Gramaj Porție (g):"/>
                        <TextBox Text="{Binding NewCantitatePortie}" Margin="0,0,0,10"/>
                        <Label Content="Stoc Inițial (Bucăți):"/>
                        <TextBox Text="{Binding NewCantitateTotala}" Margin="0,0,0,10"/>
                        <Label Content="Path Imagine (Opțional):"/>
                        <TextBox Text="{Binding NewImaginePath}" Margin="0,0,0,15"/>
                        <Button Content="Adaugă în Meniu" Height="35" Background="DarkSeaGreen" FontWeight="Bold" Command="{Binding AdaugaPreparatCommand}"/>
                    </StackPanel>

                    <Grid Grid.Column="1" Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="GESTIONARE PREPARATE EXISTENTE (CRUD)" FontSize="16" FontWeight="Bold" Foreground="DarkSlateGray" Margin="0,0,0,15"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ListaAdminPreparate}" AutoGenerateColumns="False" CanUserAddRows="False" Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Denumire" Binding="{Binding Denumire, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="Preț" Binding="{Binding Pret, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                                <DataGridTextColumn Header="Gramaj" Binding="{Binding CantitatePortie, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                                <DataGridTextColumn Header="Stoc" Binding="{Binding CantitateTotala, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                                <DataGridTemplateColumn Width="135">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="U" Background="LightBlue" Foreground="DarkBlue" FontWeight="Bold" Width="25" Margin="2" Command="{Binding DataContext.UpdatePreparatCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                <Button Content="Șterge" Background="MistyRose" Foreground="Red" FontWeight="Bold" Padding="5,2" Margin="2" Command="{Binding DataContext.StergePreparatCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>