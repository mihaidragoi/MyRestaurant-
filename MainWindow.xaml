<Window x:Class="RestaurantIncercareaDoua.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestaurantIncercareaDoua"
        mc:Ignorable="d"
        Title="Sign in" Height="450" Width="800"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="LightGoldenrodYellow"/>
            <Setter Property="Foreground" Value="DarkBlue"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="DarkBlue"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>


        <Style TargetType="TextBox">
            <Setter Property="Background" Value="LightGoldenrodYellow"/>
            <Setter Property="Foreground" Value="DarkBlue"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="DarkBlue"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="LightGoldenrodYellow"/>
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="LightGoldenrodYellow"/>
            <Setter Property="Foreground" Value="DarkBlue"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="DarkBlue"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

    </Window.Resources>

    <Grid Background="SlateBlue">
        <Button Content="Log In" HorizontalAlignment="Left" Margin="241,292,0,0" VerticalAlignment="Top" Height="39" Width="62" Command="{Binding LogInCommand}" CommandParameter="{Binding ElementName=inputPassword}"/>
        <Button Content="Sign In" HorizontalAlignment="Left" Margin="501,292,0,0" VerticalAlignment="Top" Height="39" Width="62" Command="{Binding SignInCommand}" CommandParameter="{Binding ElementName=inputPassword}"/>
        <Button Content="Guest" HorizontalAlignment="Center" Margin="0,298,0,0" VerticalAlignment="Top" Height="27" Width="44" Command="{Binding GuestCommand}" CommandParameter="{Binding ElementName=inputPassword}"/>
        <TextBox HorizontalAlignment="Center" Margin="0,167,0,0" TextWrapping="Wrap" Text="{Binding UserEmail}" VerticalAlignment="Top" Width="262" Height="24"/>
        <PasswordBox Name="inputPassword" HorizontalAlignment="Center" VerticalAlignment="Center" Width="264" Height="24" />
        <TextBlock HorizontalAlignment="Center" Margin="0,51,0,0" TextWrapping="Wrap" Text="Welcome to our Restaurant!" VerticalAlignment="Top" Height="84" Width="422"/>
        <TextBlock HorizontalAlignment="Left" Margin="532,82,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Text="🍝🍜👩🏻‍🍳🥘" Height="51" Width="258"/>
        <TextBlock HorizontalAlignment="Left" Margin="0,82,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Text="🍝🍜👩🏻‍🍳🥘" Height="51" Width="258"/>
        <Label Content="🍽️" HorizontalAlignment="Left" Margin="70,283,0,0" VerticalAlignment="Top" Height="70" Width="72" FontSize="40" RenderTransformOrigin="0.493,1.002"/>
        <Label Content="🍽️" HorizontalAlignment="Left" Margin="661,283,0,0" VerticalAlignment="Top" Height="70" Width="72" FontSize="40" RenderTransformOrigin="0.493,1.002"/>
        <Label Content="😊" HorizontalAlignment="Left" Margin="64,178,0,0" VerticalAlignment="Top" FontSize="50
               " RenderTransformOrigin="0.5,0.5">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-28.283"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Label Content="😊" HorizontalAlignment="Left" Margin="642,0,0,0" VerticalAlignment="Center" FontSize="50                " RenderTransformOrigin="0.5,0.5">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="26.78"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
    </Grid>
</Window>
