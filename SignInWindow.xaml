<Window x:Class="RestaurantIncercareaDoua.View.SignInWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestaurantIncercareaDoua.View"
        mc:Ignorable="d"
        Title="SignInWindow" Height="440" Width="474"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="BurlyWood"/>
            <Setter Property="Foreground" Value="Ivory"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="BurlyWood"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="BurlyWood"/>
            <Setter Property="Foreground" Value="Ivory"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="BurlyWood"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="BurlyWood"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="BurlyWood"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
        
    </Window.Resources>

    <Grid Margin="0,0,0,-6" Background="Azure">
        <TextBox HorizontalAlignment="Center" Margin="0,85,0,0" TextWrapping="Wrap" Text="{Binding UserFirstName,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="236"/>
        <TextBox HorizontalAlignment="Center" Margin="0,126,0,0" TextWrapping="Wrap" Text="{Binding UserLastName,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="236"/>
        <TextBox HorizontalAlignment="Center" Margin="0,166,0,0" TextWrapping="Wrap" Text="{Binding UserEmail,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="236"/>
        <TextBox HorizontalAlignment="Center" TextWrapping="Wrap" Text="{Binding UserPassword,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="236"/>
        <TextBox HorizontalAlignment="Center" Margin="0,249,0,0" TextWrapping="Wrap" Text="{Binding UserAddress,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="236"/>
        <TextBox HorizontalAlignment="Center" Margin="0,290,0,0" TextWrapping="Wrap" Text="{Binding UserPhone,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="236"/>
        <Button Content="Save" HorizontalAlignment="Center" Margin="0,340,0,0" VerticalAlignment="Top" Height="42" Width="128" Command="{Binding SaveCommand}"/>
        <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" Text="Personal Information" VerticalAlignment="Top" Width="236" Height="69"/>
        <Label Content="First Name" HorizontalAlignment="Left" Margin="27,83,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.813,-0.465"/>
        <Label Content="Last Name" HorizontalAlignment="Left" Margin="27,124,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.813,-0.465"/>
        <Label Content="Email" HorizontalAlignment="Left" Margin="27,159,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.813,-0.465"/>
        <Label Content="Password" HorizontalAlignment="Left" Margin="27,0,0,0" VerticalAlignment="Center" RenderTransformOrigin="0.813,-0.465"/>
        <Label Content="Address" HorizontalAlignment="Left" Margin="27,247,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.813,-0.465"/>
        <Label Content="Phone" HorizontalAlignment="Left" Margin="27,288,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.813,-0.465"/>

    </Grid>
</Window>
